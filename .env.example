# Anthropic API key (for quote generation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API key (for DALL-E 3 background image generation)
OPENAI_API_KEY=your_openai_api_key_here

# LinkedIn OAuth 2.0 Access Token
# Run: python get_linkedin_token.py to obtain this
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here

# LinkedIn Person URN — retrieved automatically by get_linkedin_token.py
# Format: urn:li:person:XXXXXXXX
LINKEDIN_PERSON_URN=urn:li:person:your_person_id_here
