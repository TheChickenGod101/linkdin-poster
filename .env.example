# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API key (DALL-E 3) — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# LinkedIn OAuth 2.0 Access Token — run: python get_linkedin_token.py
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here

# LinkedIn Person URN — filled automatically by get_linkedin_token.py
# Format: urn:li:person:XXXXXXXX
LINKEDIN_PERSON_URN=urn:li:person:your_person_id_here

# LinkedIn app credentials — https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# Daily post time in HH:MM (24h format)
POST_TIME=09:00
